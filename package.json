{
  "name": "loom-agent",
  "version": "0.1.0",
  "description": "Local-first AI coding agent CLI — Ollama, OpenAI-compatible, OpenRouter",
  "type": "module",
  "bin": {
    "loom": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "execa": "^9.5.1",
    "fast-glob": "^3.3.2",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lowdb": "^7.0.1",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "ollama",
    "openai",
    "coding-assistant",
    "local-llm"
  ],
  "license": "MIT"
}
